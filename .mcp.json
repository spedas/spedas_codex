{
  "mcp_servers": {
    "spedas": {
      "command": "uvx",
      "args": [
        "--with",
        "mcp>=1.26.0,<2",
        "--from",
        "git+https://github.com/spedas/spedas_agent_kit.git@52ccfcb0384dd71fa224bdc65ce813d0fa60a5c7",
        "spedas-agent-kit"
      ],
      "env": {
        "XHELIO_CDAWEB_CACHE_DIR": "${HOME}/.cache/spedas/cdaweb",
        "PDSMCP_CACHE_DIR": "${HOME}/.cache/spedas/pds",
        "XHELIO_SPICE_KERNEL_DIR": "${HOME}/.cache/spedas/spice/kernels"
      }
    }
  }
}
